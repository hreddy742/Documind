# Ollama — open source LLM (deploy on Fly.io, see infra/fly.toml)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Qdrant — open source vector database (self-hosted on Railway)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# PostgreSQL (Railway free tier)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/documind

# App
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# Frontend
VITE_API_URL=http://localhost:8000
